# ============================================================================
# Convex backend (users, progress, admin). `npx convex dev` writes these into
# .env.local automatically — you normally don't edit them by hand.
#   VITE_CONVEX_URL=https://<your-deployment>.convex.cloud
# Admin passcode is a Convex env var (server-side), NOT here:
#   npx convex env set ADMIN_PASSCODE "your-passcode"
# ============================================================================

# ============================================================================
# Code execution. By DEFAULT the app uses the FREE Wandbox engine via the
# /api/execute proxy — no key, no server, works out of the box on Vercel and in
# `npm run dev`. You usually need to set NOTHING here.
# ============================================================================

# Disable real execution (editor becomes reference-only, shows expected outputs):
# VITE_EXEC_MODE=mock

# ---------------------------------------------------------------------------
# SERVER-SIDE vars (set in Vercel → Settings → Environment Variables, NOT here).
# Only needed if you self-host Judge0 instead of using free Wandbox:
#   JUDGE0_URL=http://your-vm-ip:2358
#   JUDGE0_TOKEN=         # only if AUTHN_TOKEN is set in judge0.conf
# Optional Wandbox compiler overrides (if a default version is retired):
#   WANDBOX_C= · WANDBOX_CPP= · WANDBOX_JAVA= · WANDBOX_PYTHON=
# ---------------------------------------------------------------------------
